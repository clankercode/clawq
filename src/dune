(rule
 (target build_info.ml)
 (deps (universe))
 (action
  (bash
   "hash=$(git rev-parse --short HEAD 2>/dev/null || echo unknown); bdate=$(date -u '+%Y-%m-%d'); printf 'let version = \"0.1.0-dev\"\\nlet git_shorthash = \"%s\"\\nlet build_date = \"%s\"\\nlet version_string = \"0.1.0-dev (%s, %s)\"\\n' \"$hash\" \"$bdate\" \"$hash\" \"$bdate\" > %{target}")))


---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  breadcrumb?: string;
}

const { breadcrumb } = Astro.props;
---

<header class="header">
  <nav class="header-nav">
    <div class="header-left">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <line x1="3" y1="5" x2="17" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="3" y1="15" x2="17" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <a href="/" class="header-wordmark">
        <svg class="header-gear-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span class="wordmark">Clawq</span>
      </a>
    </div>
    <div class="header-center">
      {breadcrumb && <span class="header-breadcrumb ui-text">{breadcrumb}</span>}
    </div>
    <div class="header-right">
      <ThemeToggle />
      <a href="https://github.com/xertrov/clawq" class="header-github" aria-label="GitHub repository" target="_blank" rel="noopener noreferrer">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.338c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3rem;
    background: var(--bg-primary);
    border-bottom: 1px solid rgba(139, 115, 50, 0.3);
    z-index: 100;
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 1rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    /* Align wordmark with sidebar content on desktop */
    width: 16.25rem;
    flex-shrink: 0;
    padding-left: 0;
  }

  .sidebar-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--brass-primary);
    cursor: pointer;
    padding: 0.25rem;
    width: 2.75rem;
    height: 2.75rem;
  }

  @media (max-width: 64rem) {
    .sidebar-toggle {
      display: flex;
    }
  }

  .header-wordmark {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--brass-primary);
    text-decoration: none;
  }

  .header-wordmark:hover {
    color: var(--brass-light);
  }

  .header-wordmark .wordmark {
    font-size: 1.125rem;
  }

  .header-gear-icon {
    color: var(--brass-primary);
    width: 20px;
    height: 20px;
  }

  .header-center {
    flex: 1;
    text-align: center;
  }

  .header-breadcrumb {
    font-size: var(--fs-sm);
    color: var(--text-secondary);
  }

  .header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    width: 15rem;
    flex-shrink: 0;
  }

  .header-github {
    display: flex;
    align-items: center;
    color: var(--text-secondary);
    transition: color 150ms ease;
  }

  .header-github:hover {
    color: var(--brass-primary);
  }
</style>

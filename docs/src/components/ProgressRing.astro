---
interface Props {
  percentage: number;
  size?: number;
  label?: string;
}

const { percentage, size = 64, label } = Astro.props;
const radius = (size - 10) / 2;
const circumference = 2 * Math.PI * radius;
const dashOffset = circumference - (percentage / 100) * circumference;
const isComplete = percentage >= 100;
---
<div class="progress-ring-wrapper">
  <svg class:list={["progress-ring", { complete: isComplete }]} width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
    <!-- Track: subtle engraved channel -->
    <circle
      cx={size / 2}
      cy={size / 2}
      r={radius}
      fill="none"
      stroke="var(--bg-tertiary)"
      stroke-width="4"
    />
    <!-- Thin inner groove line -->
    <circle
      cx={size / 2}
      cy={size / 2}
      r={radius}
      fill="none"
      stroke={isComplete ? 'rgba(46,139,122,0.12)' : 'rgba(139,115,50,0.1)'}
      stroke-width="8"
    />
    <!-- Fill arc -->
    <circle
      cx={size / 2}
      cy={size / 2}
      r={radius}
      fill="none"
      stroke={isComplete ? 'var(--brass-primary)' : 'var(--brass-dark)'}
      stroke-width={isComplete ? 3 : 2.5}
      stroke-dasharray={circumference}
      stroke-dashoffset={dashOffset}
      stroke-linecap="butt"
      transform={`rotate(-90 ${size / 2} ${size / 2})`}
      opacity={isComplete ? 1 : 0.7}
    />
    <!-- Percentage text -->
    <text
      x={size / 2}
      y={size / 2}
      text-anchor="middle"
      dominant-baseline="central"
      class="ring-text"
    >{percentage}%</text>
  </svg>
  {label && <p class="ring-label">{label}</p>}
</div>

<style>
  .progress-ring-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  .progress-ring {
    overflow: visible;
  }

  .ring-text {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 0.8em;
    fill: var(--text-secondary);
  }

  .progress-ring.complete .ring-text {
    fill: var(--brass-light);
  }

  .ring-label {
    font-family: var(--font-label);
    font-size: var(--fs-xs);
    color: var(--text-secondary);
    text-align: center;
    max-width: 5rem;
    line-height: 1.3;
    margin: 0;
  }
</style>

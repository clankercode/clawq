---
import SpecBackdropDebugView from "../components/SpecBackdropDebugView.astro";
import { DEFAULT_SPEC_BACKDROP_SEED, DEFAULT_SPEC_BACKDROP_TARGET_COUNT, specPresentationOptions } from "../lib/gears/backdrop/spec_defaults.ts";
import { generateSpecBackdrop } from "../lib/gears/backdrop/spec_core.ts";
import { generatePresentedSpecBackdrop } from "../lib/gears/backdrop/spec_present.ts";
import defaultRaw from "../lib/gears/backdrop/data/topology_first.raw.json" with { type: "json" };
import defaultPresented from "../lib/gears/backdrop/data/topology_first.default.json" with { type: "json" };

const seedParam = Number(Astro.url.searchParams.get("seed") ?? DEFAULT_SPEC_BACKDROP_SEED);
const targetParam = Number(Astro.url.searchParams.get("targetCount") ?? DEFAULT_SPEC_BACKDROP_TARGET_COUNT);
const seed = Number.isFinite(seedParam) ? seedParam : DEFAULT_SPEC_BACKDROP_SEED;
const targetCount = Number.isFinite(targetParam) ? targetParam : DEFAULT_SPEC_BACKDROP_TARGET_COUNT;
const useSnapshots = !import.meta.env.DEV && seed === DEFAULT_SPEC_BACKDROP_SEED && targetCount === DEFAULT_SPEC_BACKDROP_TARGET_COUNT;

const raw = useSnapshots ? defaultRaw : generateSpecBackdrop({ mode: "topology-first", seed, targetCount });
const presented = useSnapshots
  ? defaultPresented
  : generatePresentedSpecBackdrop({
      mode: "topology-first",
      seed,
      targetCount,
      ...specPresentationOptions("topology-first", targetCount),
    });
---

<SpecBackdropDebugView
  title="Topology-First Backdrop Debug"
  mode="topology-first"
  seed={seed}
  targetCount={targetCount}
  raw={raw}
  presented={presented}
/>
